rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helper functions =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ===== Users =====
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();

      // API keys subcollection
      match /apiKeys/{keyId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if false;
      }
    }

    // ===== Organizations =====
    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ===== Scans =====
    match /scans/{scanId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
      allow update: if false;
    }

    // ===== Findings =====
    match /findings/{findingId} {
      allow read: if isAuthenticated()
        && (exists(/databases/$(database)/documents/scans/$(resource.data.scanId))
          && get(/databases/$(database)/documents/scans/$(resource.data.scanId)).data.userId == request.auth.uid
          || isAdmin());
      allow create: if isAuthenticated()
        && (exists(/databases/$(database)/documents/scans/$(request.resource.data.scanId))
          && get(/databases/$(database)/documents/scans/$(request.resource.data.scanId)).data.userId == request.auth.uid);
      allow delete: if isAdmin();
      allow update: if false;
    }

    // ===== Monitors =====
    match /monitors/{monitorId} {
      allow read: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
      allow delete: if isAuthenticated()
        && (resource.data.userId == request.auth.uid
          || isAdmin());
    }

    // ===== Health check =====
    match /health/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== Default: deny all =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
